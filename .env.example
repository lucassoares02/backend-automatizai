ORIGIN=

POSTGRESQL_EXTERNAL_URL

PORT
JWT_SECRET

URL_N8N
TOKEN_N8N
WEBHOOK_N8N_USER=
WEBHOOK_N8N_PASS=

EVOLUTION_API_URL=
TOKEN_EVOLUTION=

MAIL_HOST
MAIL_PORT
MAIL_SECURE
MAIL_USER
MAIL_PASS
MAIL_FROM

# Google OAuth (obrigatório para login social)
GOOGLE_CLIENT_ID=

# Fila de mensagens WhatsApp (Evolution -> API -> N8N)
API_BASE_URL=
MESSAGE_QUEUE_ENABLED=true
DEBOUNCE_WINDOW_MS=10000
DEBOUNCE_MAX_WAIT_MS=60000
QUEUE_DISPATCH_CRON=*/2 * * * * *
QUEUE_STUCK_CRON=* * * * *
QUEUE_STUCK_TIMEOUT_MS=180000
QUEUE_MAX_ATTEMPTS=5
QUEUE_RETRY_BACKOFF_MS=30000

# ─── Segurança / CORS ──────────────────────────────────────────────────────────
# Origens extras permitidas no CORS (além de ORIGIN), separadas por vírgula.
ALLOWED_ORIGIN=
# Validade do token JWT (padrão 7d).
JWT_EXPIRES_IN=7d
# Se definido, o webhook do Evolution passa a exigir o header x-webhook-token.
EVOLUTION_WEBHOOK_TOKEN=

# ─── Stripe (pagamentos online — Connect / contas conectadas) ──────────────────
# Chaves da conta da PLATAFORMA (não das contas conectadas).
STRIPE_SECRET_KEY=            # sk_live_... ou sk_test_...
STRIPE_PUBLISHABLE_KEY=       # pk_live_... ou pk_test_...
STRIPE_WEBHOOK_SECRET=        # whsec_... (endpoint /api/stripe/webhook)
# Taxa da plataforma retida em cada pedido (percentual do total). Ex.: 10 = 10%.
STRIPE_PLATFORM_FEE_PERCENT=10
# Moeda das cobranças (ISO 4217). Padrão: brl.
STRIPE_CURRENCY=brl
# País das contas conectadas (ISO). Padrão: BR.
STRIPE_ACCOUNT_COUNTRY=BR
# URL pública do app de pedidos (success/cancel do checkout). Ex.: https://pedido.seudominio.com
PUBLIC_APP_URL=
# URL do portal do comerciante (retorno do onboarding Connect). Se vazio, usa ORIGIN.
PORTAL_APP_URL=
# Opcionais: sobrescrevem as URLs de retorno/refresh do onboarding Connect.
STRIPE_CONNECT_RETURN_URL=
STRIPE_CONNECT_REFRESH_URL=

# ─── iFood (API oficial de parceiros) ──────────────────────────────────────────
# Credenciais de nível de aplicação (um único app iFood para toda a plataforma).
# O merchant (loja) é informado por empresa na aba iFood de "Configurações do negócio".
IFOOD_API_URL=https://merchant-api.ifood.com.br
IFOOD_CLIENT_ID=          # clientId do app iFood
IFOOD_CLIENT_SECRET=      # clientSecret do app iFood
# User-Agent enviado ao iFood — precisa parecer NAVEGADOR (o Cloudflare do iFood
# desafia UA de bot). Use um UA de browser real.
IFOOD_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
